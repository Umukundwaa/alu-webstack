global
    log /dev/log local0
    maxconn 2048
    user haproxy
    group haproxy
    daemon
    tune.ssl.default-dh-param 2048

defaults
    log global
    mode http
    option httplog
    option dontlognull
    retries 3
    option redispatch
    timeout connect 5000
    timeout client 50000
    timeout server 50000

frontend http_front
    bind *:80
    http-request redirect scheme https code 301

frontend https_front
    bind *:443 ssl crt /etc/haproxy/certs/www.umukundwa.tech.pem
    default_backend http_back

backend http_back
    balance roundrobin
    server 6790-web-01 44.211.147.102:80 check
    server 6790-web-02 35.174.154.227:80 check
